# Entra ID app registration (single-tenant, registered in the Kemyion tenant)
AZURE_CLIENT_ID=your-entra-app-client-id
AZURE_AD_CLIENT_SECRET=your-entra-client-secret

# Shared secret for the Windows packager. Generate: openssl rand -hex 32
PACKAGER_API_KEY=generate-with-openssl-rand-hex-32

# DO NOT add NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY here.
# Their absence is what keeps the catalog on the public snapshot and tokens local
# (the catalog source is chosen by isSupabaseConfigured(), not by DATABASE_MODE).
