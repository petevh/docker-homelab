# API key required in X-API-Key header for all requests — use a strong random value
DAHUA_API_KEY=changeme

# Dahua cloud API credentials (dmss-di.dolynkcloud.com)
# BEARER_TOKEN: from Authorization: Bearer header in DMSS app traffic capture
# PCS_USERNAME: from x-pcs-username header (format: uuid\<uuid>)
# DEVICE_SN:    serial number printed on VTH/VTO device label
DAHUA_BEARER_TOKEN=
DAHUA_PCS_USERNAME=
DAHUA_DEVICE_SN=BG0142EPAJEF6EF
DAHUA_DEVICE_USERNAME=user
DAHUA_DEVICE_PASSWORD=

DAHUA_CHANNEL=1
DAHUA_DOOR_INDEX=0

# Stream output (optional — defaults shown)
# STREAM=0 main/HD 1280x720, STREAM=1 sub-stream 352x288
DAHUA_STREAM=0
# WIDTH=0 means native resolution (1280x720 for main stream)
DAHUA_STREAM_WIDTH=0
DAHUA_STREAM_QUALITY=5

# Direct VTH connection — for doorbell ring detection via /events SSE
# VTH must be reachable from the container (add extra_hosts or use host networking if needed)
DAHUA_VTH_HOST=192.168.40.55
DAHUA_VTH_PORT=5000
DAHUA_VTH_USERNAME=user
DAHUA_VTH_PASSWORD=
