# API key required in X-API-Key header for all requests — use a strong random value
DAHUA_API_KEY=changeme

# VTH device credentials (DHIP, port 5000)
DAHUA_VTH_HOST=192.168.40.55
DAHUA_VTH_PORT=5000
DAHUA_VTH_USERNAME=user
DAHUA_VTH_PASSWORD=

# Door parameters — confirm correct values after testing unlock
DAHUA_CHANNEL=1
DAHUA_DOOR_INDEX=0
