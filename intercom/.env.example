# API key required in X-API-Key header for all requests — use a strong random value
DAHUA_API_KEY=changeme

# Dahua cloud API credentials (dmss-di.dolynkcloud.com)
# BEARER_TOKEN: from Authorization: Bearer header in DMSS app traffic capture
# PCS_USERNAME: from x-pcs-username header (format: uuid\<uuid>)
# DEVICE_SN:    serial number printed on VTH/VTO device label
DAHUA_BEARER_TOKEN=
DAHUA_PCS_USERNAME=
DAHUA_DEVICE_SN=BG0142EPAJEF6EF
DAHUA_DEVICE_USERNAME=user
DAHUA_DEVICE_PASSWORD=

DAHUA_CHANNEL=1
DAHUA_DOOR_INDEX=0
