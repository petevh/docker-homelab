# API keys — required in X-API-Key header (or ?key= for WS / browsers).
# Named, individually revocable: "label:key" pairs, comma-separated. Revoke one
# person by deleting their entry + `docker compose up -d`. Logs show which label
# called. Use strong random values (e.g. `openssl rand -hex 32`).
DAHUA_API_KEYS=pete:changeme1,partner:changeme2,maid:changeme3
# Legacy single key (optional) — still accepted, logged as label "default":
# DAHUA_API_KEY=changeme

# Dahua cloud API credentials (dmss-di.dolynkcloud.com)
# BEARER_TOKEN: from Authorization: Bearer header in DMSS app traffic capture
# PCS_USERNAME: from x-pcs-username header (format: uuid\<uuid>)
# DEVICE_SN:    serial number printed on VTH/VTO device label
# Cloud account login (preferred — self-refreshing Bearer, no captured token needed)
DAHUA_ACCOUNT=
DAHUA_ACCOUNT_PASSWORD=
DAHUA_AREA_CODE=971
DAHUA_COUNTRY=AE
# Static Bearer fallback (only used if account login not set; does NOT refresh)
DAHUA_BEARER_TOKEN=
DAHUA_PCS_USERNAME=
DAHUA_DEVICE_SN=
DAHUA_DEVICE_USERNAME=user
DAHUA_DEVICE_PASSWORD=

DAHUA_CHANNEL=1
DAHUA_DOOR_INDEX=0

# Talkback: hard max duration (seconds) for a talk session — backstop against a
# stuck-open mic. Push-to-talk also stops when the WebSocket closes.
DAHUA_TALK_MAX_SECONDS=180
# AES-128-ECB talk encryption key (hex) — required for talkback audio out the door
DAHUA_TALK_AES_KEY=

# Stream output (optional — defaults shown)
# STREAM=0 main/HD 1280x720, STREAM=1 sub-stream 352x288
DAHUA_STREAM=0
# WIDTH=0 means native resolution (1280x720 for main stream)
DAHUA_STREAM_WIDTH=0
DAHUA_STREAM_QUALITY=5

# Optional: push doorbell rings straight to a Home Assistant webhook, in addition
# to the /events SSE stream. Fire-and-forget POST with {event, call_id, local_time}.
# Create a matching `webhook_id: front_door` automation trigger in HA.
HA_WEBHOOK_URL=

# Direct VTH connection — for doorbell ring detection via /events SSE
# VTH must be reachable from the container (add extra_hosts or use host networking if needed)
DAHUA_VTH_HOST=192.168.40.55
DAHUA_VTH_PORT=5000
DAHUA_VTH_USERNAME=user
DAHUA_VTH_PASSWORD=

# go2rtc exec backchannel auth — set to the value of the "ha" label in DAHUA_API_KEYS
INTERCOM_API_KEY=your_ha_api_key_value_here
