# Cloudflare credentials for DNS-01 ACME challenge
CF_API_EMAIL=your-cloudflare-email@example.com
CF_DNS_API_TOKEN=your-cloudflare-dns-api-token

# Traefik dashboard basic auth
# Generate with: echo $(htpasswd -nb admin yourpassword) | sed 's/\$/\$\$/g'
TRAEFIK_BASICAUTH_USERS=admin:$$apr1$$xxxxxxxx$$xxxxxxxxxxxxxxxxxxxxxxxxxxxx
