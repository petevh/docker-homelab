# Environment files with real values
.env
**/.env

# TLS certificates and ACME state (contains private keys)
traefik/acme.json
traefik/acme.json*

# Runtime data directories
actual/actual-data/

# Sensitive config files
n8n/private-config.json

# Claude Code working directory
.claude/

# Backup/scratch files
*.save
*.bak
*.backup

# Catalog refresh logs (cron output — see intuneget/scripts/refresh-catalog.sh)
intuneget/logs/

# Frozen curation base — durable NAS copy of the catalog seed (~58MB binary, ZFS-backed).
# Too large/binary for git; the NAS share IS the durable store. See refresh-catalog.sh.
intuneget/seed/
